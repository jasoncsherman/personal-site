---
import "../styles/global.css";
import Nav from "../components/Nav.astro";
import Analytics from "@vercel/analytics/astro";
import SpeedInsights from "@vercel/speed-insights/astro";

interface Props {
	title?: string;
	description?: string;
}
const {
	title = "Jason Sherman",
	description = "A living archive of what I’m learning, noticing, reading, and making.",
} = Astro.props;
const year = new Date().getFullYear();
---

<!doctype html>
<html lang="en" data-theme="dark">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="theme-color" content="#0d0f13" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			rel="stylesheet"
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Instrument+Serif:ital@0;1&family=JetBrains+Mono:wght@400;500&display=swap"
		/>

		{/* Set theme before paint to avoid a flash of the wrong theme */}
		<script is:inline>
			(function () {
				try {
					const saved = localStorage.getItem("theme");
					if (saved === "light" || saved === "dark") {
						document.documentElement.setAttribute("data-theme", saved);
					}
				} catch (e) {}
			})();
		</script>
	</head>
	<body>
		<a href="#main" class="skip-link">Skip to content</a>
		<Nav />
		<main id="main">
			<slot />
		</main>
		<footer class="site-footer">
			<div class="container container--wide foot-inner">
				<p class="foot-name">Jason Sherman</p>
				<nav class="foot-links" aria-label="Elsewhere">
					<a href="mailto:jasoncsherman@gmail.com">Email</a>
					<a href="https://github.com/jasoncsherman" rel="me">GitHub</a>
					<a href="#">LinkedIn</a>
				</nav>
				<p class="foot-meta meta">© {year} · built with Astro</p>
			</div>
		</footer>

		<Analytics />
		<SpeedInsights />

		<style>
			main {
				min-height: 60vh;
			}
			.site-footer {
				margin-top: 80px;
				border-top: 1px solid var(--border);
				padding: 32px 0 56px;
			}
			.foot-inner {
				display: flex;
				align-items: center;
				gap: 18px;
				flex-wrap: wrap;
			}
			.foot-name {
				font-family: var(--font-display);
				font-size: 18px;
				color: var(--text);
				margin-right: auto;
			}
			.foot-links {
				display: flex;
				gap: 16px;
			}
			.foot-links a {
				font-family: var(--font-mono);
				font-size: 13px;
				color: var(--accent);
				border-bottom: 1px solid transparent;
				transition: border-color 0.15s;
			}
			.foot-links a:hover {
				border-color: var(--accent);
			}
			.foot-meta {
				width: 100%;
			}
		</style>
	</body>
</html>
