---
import { getCollection, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
	const entries = await getCollection("writing");
	return entries.map((entry) => ({
		params: { id: entry.id },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const fmt = (d: Date) =>
	d.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });
---

<Layout title={`${entry.data.title} — Jason Sherman`} description={entry.data.excerpt}>
	<article class="article container">
		<a href="/writing" class="back meta">← Writing</a>

		<header class="article-head">
			<h1>{entry.data.title}</h1>
			<p class="article-meta meta">
				{entry.data.type}
				{entry.data.topic && ` · ${entry.data.topic}`}
				{` · ${fmt(entry.data.published)}`}
				{entry.data.status === "draft" && " · Draft"}
			</p>
		</header>

		<div class="prose">
			<Content />
		</div>
	</article>
</Layout>

<style>
	.article {
		padding-top: 48px;
	}
	.back {
		display: inline-block;
		margin-bottom: 36px;
		color: var(--text-2);
		transition: color 0.15s;
	}
	.back:hover {
		color: var(--accent);
	}
	.article-head h1 {
		font-size: clamp(34px, 6vw, 54px);
		line-height: 1.05;
	}
	.article-meta {
		margin-top: 16px;
	}
	.prose {
		margin-top: 40px;
		font-size: 17.5px;
		line-height: 1.7;
		color: var(--text);
	}
	.prose :global(p) {
		margin: 0 0 1.2em;
		color: var(--text-2);
	}
	.prose :global(h2) {
		font-size: 28px;
		margin: 1.6em 0 0.5em;
		color: var(--text);
	}
	.prose :global(ul) {
		margin: 0 0 1.2em;
		padding-left: 1.2em;
		color: var(--text-2);
	}
	.prose :global(li) {
		margin: 0.3em 0;
	}
	.prose :global(a) {
		color: var(--accent);
		border-bottom: 1px solid var(--accent);
	}
	.prose :global(strong) {
		color: var(--text);
	}
</style>
