---
// Type lab — Cool archive direction, dark, with adjusted palette contrast.
// Shows the same specimen in several heading fonts so Jason can pick one.
// Body stays Inter; metadata stays mono. Only the heading/display font changes.

interface Option {
	font: string; // CSS font-family value
	name: string;
	kind: string;
	rec?: boolean;
}

const options: Option[] = [
	{ font: "'Spectral', Georgia, serif", name: "Spectral", kind: "Serif · the current pick, for reference" },
	{ font: "'Space Grotesk', sans-serif", name: "Space Grotesk", kind: "Geometric sans · clean and techy", rec: true },
	{ font: "'Geist', sans-serif", name: "Geist", kind: "Modern sans · Vercel’s UI font, very ‘dev tool’" },
	{ font: "'Bricolage Grotesque', sans-serif", name: "Bricolage Grotesque", kind: "Display grotesque · more character / personality" },
	{ font: "'Schibsted Grotesk', sans-serif", name: "Schibsted Grotesk", kind: "Editorial grotesque · crisp, contemporary" },
	{ font: "'JetBrains Mono', monospace", name: "JetBrains Mono", kind: "Mono headings · leans all-in on the terminal/archive vibe", rec: true },
];

const navItems = ["Home", "Writing", "Photos", "AI Log", "Bookshelf", "Projects", "Now", "About"];
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="robots" content="noindex" />
		<title>Type Lab — Cool Archive</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			rel="stylesheet"
			href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,500;12..96,600&family=Geist:wght@400;500;600&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500;600&family=Schibsted+Grotesk:wght@500;600;700&family=Space+Grotesk:wght@400;500;600;700&family=Spectral:wght@400;500;600&display=swap"
		/>
	</head>
	<body>
		<main>
			<header class="head">
				<p class="kicker">Cool archive · type lab</p>
				<h1>Pick a heading font</h1>
				<p class="lede">
					Same words, same palette (now with the <strong>surface / border / background</strong> contrast
					opened up), six heading fonts. Body text stays Inter and metadata stays mono throughout —
					only the headings change. The two I’d lean toward are marked
					<span class="rec-chip">my pick</span>.
				</p>

				<div class="palette">
					<p class="block-title">Adjusted palette</p>
					<div class="swatches">
						<div class="sw"><span class="chip" style="background:var(--bg)"></span><span>Background</span></div>
						<div class="sw"><span class="chip" style="background:var(--surface)"></span><span>Surface</span></div>
						<div class="sw"><span class="chip" style="background:var(--surface-2)"></span><span>Surface 2</span></div>
						<div class="sw"><span class="chip" style="background:var(--border)"></span><span>Border</span></div>
						<div class="sw"><span class="chip" style="background:var(--text)"></span><span>Text</span></div>
						<div class="sw"><span class="chip" style="background:var(--text-2)"></span><span>Secondary</span></div>
						<div class="sw"><span class="chip" style="background:var(--accent)"></span><span>Accent</span></div>
					</div>
				</div>
			</header>

			<div class="grid">
				{
					options.map((o) => (
						<article class="opt" style={`--font-display:${o.font}`}>
							<div class="opt-head">
								<span class="opt-name">{o.name}</span>
								<span class="opt-kind">{o.kind}</span>
								{o.rec && <span class="rec-chip">my pick</span>}
							</div>

							<h2 class="spec">A living archive of what I’m learning, noticing, and making.</h2>

							<nav class="mininav" aria-label={`${o.name} sample nav`}>
								{navItems.map((it, i) => (
									<a href="#" class={i === 0 ? "current" : ""}>
										{it}
									</a>
								))}
							</nav>

							<p class="body">
								Body text stays in a readable sans so prose feels calm. The heading above is the only
								thing changing card to card — judge it on the display line and the section titles.
							</p>

							<div class="mini">
								<div class="mini-book">
									<span class="cover" aria-hidden="true" />
									<div>
										<h3 class="mini-title">The Master and Margarita</h3>
										<p class="mini-sub">Mikhail Bulgakov</p>
									</div>
									<span class="tag">Reading</span>
								</div>
								<p class="meta">NOTE · LEARNING · 4 MIN · DRAFT</p>
							</div>
						</article>
					))
				}
			</div>

			<footer class="foot">
				<p>Type lab · sample content for layout only · not indexed</p>
			</footer>
		</main>

		<style>
			:root {
				/* Cool archive — dark, contrast opened up */
				--bg: #0d0f13;
				--surface: #161b22;
				--surface-2: #20262f;
				--text: #e8e4da;
				--text-2: #a6acb6;
				--muted: #6b7280;
				--border: #333b47;
				--accent: #d2a35a;
				--accent-soft: #332b1c;
				--accent-ink: #0d0f13;
				--font-body: "Inter", system-ui, sans-serif;
				--font-mono: "JetBrains Mono", ui-monospace, monospace;
			}

			* {
				box-sizing: border-box;
			}
			body {
				margin: 0;
				background: var(--bg);
				color: var(--text);
				font-family: var(--font-body);
				-webkit-font-smoothing: antialiased;
			}
			main {
				max-width: 920px;
				margin: 0 auto;
				padding: 64px 24px 80px;
			}

			.kicker {
				font-family: var(--font-mono);
				font-size: 12px;
				letter-spacing: 0.12em;
				text-transform: uppercase;
				color: var(--accent);
				margin: 0 0 12px;
			}
			.head h1 {
				font-family: "Space Grotesk", sans-serif;
				font-weight: 600;
				font-size: clamp(32px, 6vw, 48px);
				line-height: 1.05;
				margin: 0 0 16px;
			}
			.lede {
				font-size: 17px;
				line-height: 1.6;
				color: var(--text-2);
				max-width: 64ch;
				margin: 0 0 32px;
			}
			.lede strong {
				color: var(--text);
			}
			.rec-chip {
				display: inline-block;
				font-family: var(--font-mono);
				font-size: 10.5px;
				letter-spacing: 0.06em;
				text-transform: uppercase;
				color: var(--accent);
				border: 1px solid var(--accent);
				border-radius: 999px;
				padding: 2px 8px;
				vertical-align: middle;
			}

			.block-title {
				font-family: var(--font-mono);
				font-size: 11px;
				letter-spacing: 0.14em;
				text-transform: uppercase;
				color: var(--muted);
				margin: 0 0 14px;
			}
			.palette {
				padding: 22px;
				background: var(--surface);
				border: 1px solid var(--border);
				border-radius: 10px;
			}
			.swatches {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(86px, 1fr));
				gap: 14px;
			}
			.sw {
				display: flex;
				flex-direction: column;
				gap: 6px;
				font-size: 12px;
				color: var(--text-2);
			}
			.chip {
				height: 46px;
				border-radius: 6px;
				border: 1px solid var(--border);
			}

			/* ---- Option grid ---- */
			.grid {
				margin-top: 40px;
				display: grid;
				gap: 22px;
			}
			.opt {
				background: var(--surface);
				border: 1px solid var(--border);
				border-radius: 12px;
				padding: 28px;
			}
			.opt-head {
				display: flex;
				align-items: center;
				gap: 12px;
				flex-wrap: wrap;
				padding-bottom: 18px;
				margin-bottom: 22px;
				border-bottom: 1px solid var(--border);
			}
			.opt-name {
				font-family: var(--font-mono);
				font-size: 13px;
				font-weight: 500;
				color: var(--text);
				letter-spacing: 0.02em;
			}
			.opt-kind {
				font-size: 13px;
				color: var(--muted);
			}

			.spec {
				font-family: var(--font-display);
				font-weight: 600;
				font-size: clamp(24px, 3.6vw, 34px);
				line-height: 1.12;
				margin: 0 0 20px;
				color: var(--text);
			}

			.mininav {
				display: flex;
				flex-wrap: wrap;
				gap: 16px;
				padding-bottom: 20px;
			}
			.mininav a {
				font-family: var(--font-mono);
				font-size: 12.5px;
				color: var(--text-2);
				text-decoration: none;
				padding: 2px 0;
				border-bottom: 1.5px solid transparent;
			}
			.mininav a.current {
				color: var(--accent);
				border-color: var(--accent);
			}

			.body {
				font-size: 15.5px;
				line-height: 1.6;
				color: var(--text-2);
				max-width: 60ch;
				margin: 0 0 22px;
			}

			.mini {
				display: flex;
				flex-direction: column;
				gap: 16px;
				padding-top: 20px;
				border-top: 1px solid var(--border);
			}
			.mini-book {
				display: flex;
				align-items: center;
				gap: 14px;
			}
			.cover {
				flex: none;
				width: 38px;
				height: 54px;
				border-radius: 3px;
				background: linear-gradient(150deg, var(--surface-2), var(--accent-soft));
				border: 1px solid var(--border);
			}
			.mini-book > div {
				flex: 1;
			}
			.mini-title {
				font-family: var(--font-display);
				font-weight: 500;
				font-size: 17px;
				margin: 0 0 2px;
				color: var(--text);
			}
			.mini-sub {
				margin: 0;
				font-size: 13.5px;
				color: var(--text-2);
			}
			.tag {
				font-family: var(--font-mono);
				font-size: 11.5px;
				letter-spacing: 0.04em;
				padding: 4px 10px;
				border-radius: 4px;
				background: var(--accent);
				color: var(--accent-ink);
			}
			.meta {
				font-family: var(--font-mono);
				font-size: 12px;
				letter-spacing: 0.08em;
				color: var(--muted);
				margin: 0;
			}

			.foot {
				margin-top: 44px;
				font-family: var(--font-mono);
				font-size: 12px;
				color: var(--muted);
			}

			a:focus-visible {
				outline: 2px solid var(--accent);
				outline-offset: 3px;
				border-radius: 2px;
			}
		</style>
	</body>
</html>
