---
// Style tile — Phase 1 review gate (Round 2).
// Two finalist palettes (Cool archive / Warm editorial), each viewable in
// light or dark, with serif or sans display type — driven by toggles up top.
// All content is SAMPLE placeholder for layout evaluation only.
import Showcase from "../components/Showcase.astro";
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="robots" content="noindex" />
		<title>Style Tile — Personal Site</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			rel="stylesheet"
			href="https://fonts.googleapis.com/css2?family=Archivo:wght@500;600;700&family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600&family=IBM+Plex+Mono:wght@400;500&family=Inter:wght@400;500;600&family=Inter+Tight:wght@500;600&family=JetBrains+Mono:wght@400;500&family=Newsreader:opsz,wght@6..72,400;6..72,500&family=Spectral:wght@400;500;600&display=swap"
		/>
	</head>
	<body data-theme="dark" data-display="serif">
		<header class="page-head">
			<p class="kicker">Personal site · Phase 1 · Round 2</p>
			<h1>Two finalists, your way</h1>
			<p class="lede">
				Down to <strong>Cool archive</strong> and <strong>Warm editorial</strong>. Use the switches to
				flip each between <strong>light / dark</strong> and <strong>serif / sans</strong> headings, so you
				can see every combination — including the warm palette in dark mode. Metadata stays mono. Text
				is sample placeholder for judging the look.
			</p>
		</header>

		<div class="controls" role="group" aria-label="Preview controls">
			<div class="control">
				<span class="control-label">Theme</span>
				<div class="segmented">
					<button data-set-theme="light" type="button">Light</button>
					<button data-set-theme="dark" type="button">Dark</button>
				</div>
			</div>
			<div class="control">
				<span class="control-label">Headings</span>
				<div class="segmented">
					<button data-set-display="serif" type="button">Serif</button>
					<button data-set-display="sans" type="button">Sans</button>
				</div>
			</div>
		</div>

		<section class="panel palette-archive" aria-label="Cool archive palette">
			<div class="panel-inner">
				<div class="panel-label">
					<span class="panel-num">01</span>
					<div>
						<h2>Cool archive</h2>
						<p>Ink and slate, warm amber accent. Calm, literate, quietly technical.</p>
					</div>
				</div>
				<Showcase />
			</div>
		</section>

		<section class="panel palette-editorial" aria-label="Warm editorial palette">
			<div class="panel-inner">
				<div class="panel-label">
					<span class="panel-num">02</span>
					<div>
						<h2>Warm editorial</h2>
						<p>Paper and ember, terracotta accent. Personal, warm, literary.</p>
					</div>
				</div>
				<Showcase />
			</div>
		</section>

		<footer class="page-foot">
			<p>Style tile · sample content for layout only · not indexed</p>
		</footer>

		<style>
			* {
				box-sizing: border-box;
			}
			body {
				margin: 0;
				background: #0a0b0d;
				color: #c9c9cf;
				font-family: "Inter", system-ui, sans-serif;
				-webkit-font-smoothing: antialiased;
			}

			/* ---- Page chrome ---- */
			.page-head {
				max-width: 760px;
				margin: 0 auto;
				padding: 72px 24px 28px;
			}
			.kicker {
				font-family: "JetBrains Mono", monospace;
				font-size: 12px;
				letter-spacing: 0.12em;
				text-transform: uppercase;
				color: #6a6a72;
				margin: 0 0 12px;
			}
			.page-head h1 {
				font-family: "Spectral", Georgia, serif;
				font-weight: 500;
				font-size: clamp(32px, 6vw, 50px);
				line-height: 1.05;
				margin: 0 0 18px;
				color: #fff;
			}
			.lede {
				font-size: 17px;
				line-height: 1.6;
				color: #c9c9cf;
				margin: 0;
			}
			.lede strong {
				color: #fff;
			}

			/* ---- Sticky controls ---- */
			.controls {
				position: sticky;
				top: 0;
				z-index: 10;
				display: flex;
				flex-wrap: wrap;
				gap: 28px;
				justify-content: center;
				padding: 16px 24px;
				background: rgba(10, 11, 13, 0.86);
				backdrop-filter: blur(8px);
				border-bottom: 1px solid #1f1f25;
			}
			.control {
				display: flex;
				align-items: center;
				gap: 10px;
			}
			.control-label {
				font-family: "JetBrains Mono", monospace;
				font-size: 11px;
				letter-spacing: 0.1em;
				text-transform: uppercase;
				color: #6a6a72;
			}
			.segmented {
				display: inline-flex;
				border: 1px solid #2a2a30;
				border-radius: 999px;
				overflow: hidden;
			}
			.segmented button {
				font-family: "JetBrains Mono", monospace;
				font-size: 12.5px;
				color: #c9c9cf;
				background: transparent;
				border: 0;
				padding: 7px 16px;
				cursor: pointer;
				transition: background 0.15s, color 0.15s;
			}
			.segmented button:hover {
				color: #fff;
			}
			.segmented button[aria-pressed="true"] {
				background: #e8e8ee;
				color: #0a0b0d;
			}

			.page-foot {
				max-width: 760px;
				margin: 0 auto;
				padding: 40px 24px 80px;
				font-family: "JetBrains Mono", monospace;
				font-size: 12px;
				color: #6a6a72;
			}

			/* ---- Panels ---- */
			.panel {
				background: var(--bg);
				color: var(--text);
				font-family: var(--font-body);
			}
			.panel-inner {
				max-width: 760px;
				margin: 0 auto;
				padding: 56px 24px 72px;
				display: flex;
				flex-direction: column;
				gap: 40px;
			}
			.panel-label {
				display: flex;
				gap: 18px;
				align-items: baseline;
			}
			.panel-num {
				font-family: var(--font-mono);
				font-size: 13px;
				color: var(--accent);
				letter-spacing: 0.1em;
			}
			.panel-label h2 {
				font-family: var(--font-display);
				font-weight: 600;
				font-size: 28px;
				margin: 0 0 6px;
				color: var(--text);
			}
			.panel-label p {
				margin: 0;
				color: var(--text-2);
				font-size: 15px;
				line-height: 1.5;
			}

			:focus-visible {
				outline: 2px solid var(--accent, #6a8cff);
				outline-offset: 3px;
				border-radius: 2px;
			}

			/* ---- Font role tokens (display swaps with the Headings toggle) ---- */
			.palette-archive {
				--display-serif: "Spectral", Georgia, serif;
				--display-sans: "Inter Tight", system-ui, sans-serif;
				--body-serif: "Inter", system-ui, sans-serif;
				--body-sans: "Inter", system-ui, sans-serif;
				--font-mono: "JetBrains Mono", ui-monospace, monospace;
			}
			.palette-editorial {
				--display-serif: "Fraunces", Georgia, serif;
				--display-sans: "Archivo", system-ui, sans-serif;
				--body-serif: "Newsreader", Georgia, serif;
				--body-sans: "Inter", system-ui, sans-serif;
				--font-mono: "IBM Plex Mono", ui-monospace, monospace;
			}
			.panel {
				--font-display: var(--display-serif);
				--font-body: var(--body-serif);
			}
			body[data-display="sans"] .panel {
				--font-display: var(--display-sans);
				--font-body: var(--body-sans);
			}

			/* ---- Color tokens per palette × theme ---- */
			body[data-theme="dark"] .palette-archive {
				--bg: #0f1216;
				--surface: #171b21;
				--surface-2: #1d222a;
				--text: #e8e4da;
				--text-2: #a7a298;
				--muted: #6e6a61;
				--border: #2a3039;
				--accent: #d2a35a;
				--accent-soft: #33301f;
				--accent-ink: #0f1216;
			}
			body[data-theme="light"] .palette-archive {
				--bg: #f7f6f2;
				--surface: #efeee8;
				--surface-2: #e7e5dc;
				--text: #1b1e23;
				--text-2: #54585f;
				--muted: #8a8d92;
				--border: #dcd9cf;
				--accent: #9a6b1e;
				--accent-soft: #efe4cf;
				--accent-ink: #ffffff;
			}
			body[data-theme="dark"] .palette-editorial {
				--bg: #1a1512;
				--surface: #221c18;
				--surface-2: #2b231d;
				--text: #efe6d8;
				--text-2: #bcae9c;
				--muted: #857a6b;
				--border: #352c25;
				--accent: #d9764a;
				--accent-soft: #3a2a20;
				--accent-ink: #1a1512;
			}
			body[data-theme="light"] .palette-editorial {
				--bg: #f5efe3;
				--surface: #efe7d6;
				--surface-2: #e9dfca;
				--text: #2c2722;
				--text-2: #5d564c;
				--muted: #8c8377;
				--border: #ddd1bb;
				--accent: #b1542d;
				--accent-soft: #eddcc8;
				--accent-ink: #ffffff;
			}

			@media (prefers-reduced-motion: reduce) {
				* {
					transition: none !important;
				}
			}
		</style>

		<script is:inline>
			const root = document.body;
			const KEY = "styletile-v2";
			let state = { theme: "dark", display: "serif" };
			try {
				state = { ...state, ...JSON.parse(localStorage.getItem(KEY) || "{}") };
			} catch (e) {}

			function apply() {
				root.dataset.theme = state.theme;
				root.dataset.display = state.display;
				document.querySelectorAll("[data-set-theme]").forEach((b) => {
					b.setAttribute("aria-pressed", String(b.dataset.setTheme === state.theme));
				});
				document.querySelectorAll("[data-set-display]").forEach((b) => {
					b.setAttribute("aria-pressed", String(b.dataset.setDisplay === state.display));
				});
				try {
					localStorage.setItem(KEY, JSON.stringify(state));
				} catch (e) {}
			}

			document.querySelectorAll("[data-set-theme]").forEach((b) =>
				b.addEventListener("click", () => {
					state.theme = b.dataset.setTheme;
					apply();
				})
			);
			document.querySelectorAll("[data-set-display]").forEach((b) =>
				b.addEventListener("click", () => {
					state.display = b.dataset.setDisplay;
					apply();
				})
			);
			document.querySelectorAll("[data-toggle-theme]").forEach((b) =>
				b.addEventListener("click", () => {
					state.theme = state.theme === "dark" ? "light" : "dark";
					apply();
				})
			);

			apply();
		</script>
	</body>
</html>
