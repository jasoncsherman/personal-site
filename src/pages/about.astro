---
import Layout from "../layouts/Layout.astro";
import PageHeader from "../components/PageHeader.astro";
---

<Layout
	title="About — Jason Sherman"
	description="Who I am, how I think and work, and how to get in touch."
>
	<PageHeader kicker="About · Collaborate" title="About" />

	<div class="container">
		<div class="prose">
			<p class="lead">
				I'm Jason — exploring how AI, taste, and systems help people think and make better things. This
				site is a living archive of that exploration: the work, the notes, and the things catching my
				eye while they're still forming.
			</p>

			<p class="placeholder meta">↓ Placeholder copy — replace with your real background.</p>

			<h2>How I work</h2>
			<p>
				I like building small, careful tools and keeping systems light enough to actually maintain. I
				learn by making things in the open and writing about what I find. I care about clarity, good
				defaults, and finishing the things that are closest to done.
			</p>

			<h2>Collaborate</h2>
			<p>
				I'm open to conversations about AI and learning, personal tools and systems, and projects where
				curiosity and craft matter more than scale. If that's you, say hello.
			</p>
		</div>

		<div class="contact">
			<p class="contact-line">Get in touch</p>
			<div class="contact-links">
				<a href="mailto:jasoncsherman@gmail.com">Email</a>
				<a href="https://github.com/jasoncsherman" rel="me">GitHub</a>
				<a href="#">LinkedIn</a>
				<a href="/resume.pdf" class="resume">Résumé ↓</a>
			</div>
		</div>
	</div>
</Layout>

<style>
	.prose {
		margin-top: 48px;
		font-size: 17.5px;
		line-height: 1.7;
		color: var(--text-2);
	}
	.lead {
		font-family: var(--font-display);
		font-size: clamp(22px, 3.4vw, 30px);
		line-height: 1.35;
		color: var(--text);
		margin-bottom: 1em;
	}
	.placeholder {
		margin: 0 0 2em;
	}
	.prose h2 {
		font-size: 28px;
		color: var(--text);
		margin: 1.8em 0 0.5em;
	}
	.prose p {
		margin: 0 0 1.1em;
	}

	.contact {
		margin-top: 56px;
		padding-top: 28px;
		border-top: 1px solid var(--border);
	}
	.contact-line {
		font-family: var(--font-mono);
		font-size: 12px;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--muted);
		margin-bottom: 16px;
	}
	.contact-links {
		display: flex;
		flex-wrap: wrap;
		gap: 20px;
	}
	.contact-links a {
		font-family: var(--font-mono);
		font-size: 14px;
		color: var(--accent);
		border-bottom: 1px solid transparent;
		transition: border-color 0.15s;
	}
	.contact-links a:hover {
		border-color: var(--accent);
	}
	.resume {
		color: var(--text-2) !important;
	}
</style>
