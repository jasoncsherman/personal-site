---
// Site navigation: serif wordmark + mono nav links + theme toggle.
// (Nav treatment is intentionally simple for now — flagged for a later revisit.)
const path = Astro.url.pathname;
const items = [
	{ href: "/", label: "Home" },
	{ href: "/writing", label: "Writing" },
	{ href: "/photos", label: "Photos" },
	{ href: "/field-notes", label: "Field Notes" },
	{ href: "/bookshelf", label: "Bookshelf" },
	{ href: "/projects", label: "Projects" },
	{ href: "/now", label: "Now" },
	{ href: "/about", label: "About" },
];
const isActive = (href: string) =>
	href === "/" ? path === "/" : path === href || path.startsWith(href + "/");
---

<header class="site-header">
	<div class="container container--wide bar">
		<a href="/" class="wordmark">Jason Sherman</a>

		<nav class="nav" aria-label="Primary">
			{
				items.map((it) => (
					<a href={it.href} class:list={["nav-link", { active: isActive(it.href) }]} aria-current={isActive(it.href) ? "page" : undefined}>
						{it.label}
					</a>
				))
			}
		</nav>

		<button id="theme-toggle" class="theme-btn" type="button" aria-label="Toggle light or dark theme">
			<span class="i-dark" aria-hidden="true">☾</span>
			<span class="i-light" aria-hidden="true">☀</span>
		</button>
	</div>
</header>

<style>
	.site-header {
		border-bottom: 1px solid var(--border);
		background: var(--bg);
	}
	.bar {
		display: flex;
		align-items: center;
		gap: 20px;
		flex-wrap: wrap;
		padding-top: 18px;
		padding-bottom: 18px;
	}
	.wordmark {
		font-family: var(--font-display);
		font-size: 22px;
		color: var(--text);
		margin-right: auto;
	}
	.nav {
		display: flex;
		flex-wrap: wrap;
		gap: 16px;
	}
	.nav-link {
		font-family: var(--font-mono);
		font-size: 12.5px;
		letter-spacing: 0.02em;
		color: var(--text-2);
		padding: 2px 0;
		border-bottom: 1.5px solid transparent;
		transition: color 0.15s, border-color 0.15s;
	}
	.nav-link:hover {
		color: var(--text);
	}
	.nav-link.active {
		color: var(--accent);
		border-color: var(--accent);
	}
	.theme-btn {
		display: inline-grid;
		place-items: center;
		width: 34px;
		height: 34px;
		border-radius: 999px;
		border: 1px solid var(--border);
		background: var(--surface);
		color: var(--text);
		cursor: pointer;
		font-size: 15px;
		line-height: 1;
		transition: border-color 0.15s;
	}
	.theme-btn:hover {
		border-color: var(--accent);
	}
	:global(:root[data-theme="dark"]) .theme-btn .i-dark {
		display: none;
	}
	:global(:root[data-theme="light"]) .theme-btn .i-light {
		display: none;
	}

	@media (max-width: 640px) {
		.wordmark {
			margin-right: 0;
			width: 100%;
		}
		.nav {
			order: 3;
			width: 100%;
		}
	}
</style>

<script is:inline>
	(function () {
		const btn = document.getElementById("theme-toggle");
		if (!btn) return;
		btn.addEventListener("click", function () {
			const root = document.documentElement;
			const next = root.getAttribute("data-theme") === "light" ? "dark" : "light";
			root.setAttribute("data-theme", next);
			try {
				localStorage.setItem("theme", next);
			} catch (e) {}
		});
	})();
</script>
