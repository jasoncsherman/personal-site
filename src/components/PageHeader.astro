---
interface Props {
	kicker?: string;
	title: string;
	intro?: string;
}
const { kicker, title, intro } = Astro.props;
---

<header class="page-header container container--wide">
	{kicker && <p class="kicker">{kicker}</p>}
	<h1>{title}</h1>
	{intro && <p class="page-intro">{intro}</p>}
</header>

<style>
	.page-header {
		padding-top: 64px;
		padding-bottom: 8px;
	}
	.page-header h1 {
		font-size: clamp(40px, 7vw, 64px);
		line-height: 1.02;
		margin: 14px 0 0;
	}
	.page-intro {
		font-size: 18px;
		line-height: 1.6;
		color: var(--text-2);
		max-width: 60ch;
		margin: 20px 0 0;
	}
</style>
