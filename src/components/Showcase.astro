---
// Shared component showcase used by the style tile.
// Rendered once per palette; color + font tokens are inherited from the
// wrapping .panel element (set in style-tile.astro), so the same markup
// renders differently per palette / theme / display-font.
// All content is SAMPLE placeholder for layout evaluation only.

const navItems = ["Home", "Writing", "Photos", "AI Log", "Bookshelf", "Projects", "Now", "About"];
---

<div class="showcase">
	{/* Brand + navigation (with theme toggle preview) */}
	<header class="brand">
		<div class="brand-id">
			<span class="brand-name">Jason Sherman</span>
			<span class="brand-pos">
				Exploring how AI, taste, and systems help people think and make better things.
			</span>
		</div>
		<div class="brand-right">
			<nav class="site-nav" aria-label="Sample site navigation">
				{navItems.map((item, i) => (
					<a href="#" class={i === 0 ? "current" : ""} aria-current={i === 0 ? "page" : undefined}>
						{item}
					</a>
				))}
			</nav>
			<button class="theme-btn" data-toggle-theme type="button" aria-label="Toggle light or dark theme">
				<span class="i-dark" aria-hidden="true">☾</span>
				<span class="i-light" aria-hidden="true">☀</span>
			</button>
		</div>
	</header>

	{/* Palette (updates live with the theme toggle) */}
	<div class="block">
		<p class="block-title">Palette</p>
		<div class="swatches">
			<div class="swatch"><span class="chip" style="background:var(--bg)"></span><span class="chip-label">Background</span></div>
			<div class="swatch"><span class="chip" style="background:var(--surface)"></span><span class="chip-label">Surface</span></div>
			<div class="swatch"><span class="chip" style="background:var(--text)"></span><span class="chip-label">Text</span></div>
			<div class="swatch"><span class="chip" style="background:var(--text-2)"></span><span class="chip-label">Secondary</span></div>
			<div class="swatch"><span class="chip" style="background:var(--muted)"></span><span class="chip-label">Muted</span></div>
			<div class="swatch"><span class="chip" style="background:var(--border)"></span><span class="chip-label">Border</span></div>
			<div class="swatch"><span class="chip" style="background:var(--accent)"></span><span class="chip-label">Accent</span></div>
		</div>
	</div>

	{/* Typography */}
	<div class="block">
		<p class="block-title">Typography</p>
		<div class="type-specimen">
			<p class="t-display">A living archive of what I’m learning, noticing, and making.</p>
			<p class="t-body">
				Body text sets the reading rhythm of the site — long enough to feel like prose, calm enough
				to disappear. Notes, reflections, and field notes all live in this voice, one readable column
				at a time.
			</p>
			<p class="t-meta">NOTE · LEARNING · 4 MIN READ · DRAFT</p>
		</div>
	</div>

	{/* Status labels */}
	<div class="block">
		<p class="block-title">Status labels</p>
		<div class="labels">
			<span class="tag tag-accent">Reading</span>
			<span class="tag">Read</span>
			<span class="tag tag-outline">TBR</span>
			<span class="tag tag-accent">Active</span>
			<span class="tag">Shipped</span>
			<span class="tag tag-outline">Draft</span>
		</div>
	</div>

	{/* Writing entry */}
	<div class="block">
		<p class="block-title">Writing entry</p>
		<ul class="index">
			<li class="index-item">
				<div class="ii-main">
					<h3>Notes on learning in public</h3>
					<p>What changes when you publish the unfinished thing — and why the discomfort is most of the point.</p>
				</div>
				<p class="ii-meta">Note · Learning · 4 min · 2026·06</p>
			</li>
			<li class="index-item">
				<div class="ii-main">
					<h3>The tools that earn their keep</h3>
					<p>A short field note on keeping a system small enough to actually maintain.</p>
				</div>
				<p class="ii-meta">Field note · Systems · 2 min · 2026·05</p>
			</li>
		</ul>
	</div>

	{/* Bookshelf */}
	<div class="block">
		<p class="block-title">Bookshelf item</p>
		<ul class="shelf">
			<li class="book">
				<span class="cover" aria-hidden="true"></span>
				<div class="book-main">
					<h3>The Master and Margarita</h3>
					<p class="book-author">Mikhail Bulgakov</p>
					<p class="book-why">Reread on a whim. The cat with the pistol still gets me.</p>
				</div>
				<span class="tag tag-accent">Reading</span>
			</li>
			<li class="book">
				<span class="cover" aria-hidden="true"></span>
				<div class="book-main">
					<h3>Thinking in Systems</h3>
					<p class="book-author">Donella Meadows</p>
					<p class="book-why">Changed how I see feedback loops in everything I build.</p>
				</div>
				<span class="tag">Read</span>
			</li>
		</ul>
	</div>

	{/* Photo album */}
	<div class="block">
		<p class="block-title">Photo album preview</p>
		<div class="album">
			<div class="album-img" aria-hidden="true"></div>
			<div class="album-meta">
				<h3>Morning light, kitchen table</h3>
				<p class="album-why">The ordinary half-hour before the day starts — kept because it keeps coming back.</p>
				<p class="ii-meta">Light · Winter 2026 · Quiet</p>
			</div>
		</div>
	</div>

	{/* AI log */}
	<div class="block">
		<p class="block-title">AI log entry</p>
		<article class="log">
			<p class="ii-meta">2026·06·15 · Astro · Experiment</p>
			<h3>Trying content collections</h3>
			<p>
				Moved the bookshelf to typed Markdown files. A bad status now fails the build loudly instead
				of silently breaking a page — surprisingly reassuring.
			</p>
			<p class="log-lesson"><span class="lesson-key">Lesson</span> Let the schema catch your typos.</p>
		</article>
	</div>

	{/* Project */}
	<div class="block">
		<p class="block-title">Project entry</p>
		<article class="project">
			<div class="project-head">
				<h3>This website</h3>
				<span class="tag tag-accent">Active</span>
			</div>
			<p>A content-first living archive, built in the open.</p>
			<dl class="meta-table">
				<div><dt>Kind</dt><dd>Personal system</dd></div>
				<div><dt>Started</dt><dd>June 2026</dd></div>
				<div><dt>Current question</dt><dd>Which visual direction feels like me?</dd></div>
				<div><dt>Next step</dt><dd>Pick a direction, build the pages</dd></div>
			</dl>
		</article>
	</div>

	{/* Contact */}
	<div class="block">
		<p class="block-title">Contact / Elsewhere</p>
		<div class="contact">
			<p class="contact-line">Open to conversations about AI, learning systems, and making things carefully.</p>
			<div class="elsewhere">
				<a href="#">Email</a>
				<a href="#">GitHub</a>
				<a href="#">LinkedIn</a>
				<a href="#">Résumé ↓</a>
			</div>
		</div>
	</div>
</div>

<style>
	.showcase {
		display: flex;
		flex-direction: column;
		gap: 40px;
	}

	/* Brand + nav */
	.brand {
		display: flex;
		justify-content: space-between;
		align-items: flex-end;
		gap: 24px;
		flex-wrap: wrap;
		padding-bottom: 24px;
		border-bottom: 1px solid var(--border);
	}
	.brand-id {
		display: flex;
		flex-direction: column;
		gap: 6px;
		max-width: 340px;
	}
	.brand-name {
		font-family: var(--font-display);
		font-weight: 600;
		font-size: 22px;
		color: var(--text);
	}
	.brand-pos {
		font-size: 14px;
		line-height: 1.45;
		color: var(--text-2);
	}
	.brand-right {
		display: flex;
		align-items: center;
		gap: 16px;
		flex-wrap: wrap;
	}
	.site-nav {
		display: flex;
		flex-wrap: wrap;
		gap: 16px;
	}
	.site-nav a {
		font-family: var(--font-mono);
		font-size: 12.5px;
		letter-spacing: 0.02em;
		color: var(--text-2);
		text-decoration: none;
		padding: 2px 0;
		border-bottom: 1.5px solid transparent;
		transition: color 0.15s, border-color 0.15s;
	}
	.site-nav a:hover,
	.site-nav a:focus-visible {
		color: var(--text);
	}
	.site-nav a.current {
		color: var(--accent);
		border-color: var(--accent);
	}
	.theme-btn {
		display: inline-grid;
		place-items: center;
		width: 34px;
		height: 34px;
		border-radius: 999px;
		border: 1px solid var(--border);
		background: var(--surface);
		color: var(--text);
		cursor: pointer;
		font-size: 15px;
		line-height: 1;
		transition: border-color 0.15s, background 0.15s;
	}
	.theme-btn:hover {
		border-color: var(--accent);
	}
	/* show the icon for the mode you'd switch TO */
	:global(body[data-theme="dark"]) .theme-btn .i-dark {
		display: none;
	}
	:global(body[data-theme="light"]) .theme-btn .i-light {
		display: none;
	}

	.block-title {
		font-family: var(--font-mono);
		font-size: 11px;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--muted);
		margin: 0 0 16px;
	}

	/* Palette */
	.swatches {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(92px, 1fr));
		gap: 14px;
	}
	.swatch {
		display: flex;
		flex-direction: column;
		gap: 6px;
	}
	.chip {
		height: 52px;
		border-radius: 6px;
		border: 1px solid var(--border);
	}
	.chip-label {
		font-size: 12px;
		color: var(--text-2);
	}

	/* Typography */
	.type-specimen {
		display: flex;
		flex-direction: column;
		gap: 18px;
	}
	.t-display {
		font-family: var(--font-display);
		font-weight: 500;
		font-size: clamp(26px, 4.4vw, 38px);
		line-height: 1.12;
		margin: 0;
		color: var(--text);
	}
	.t-body {
		font-family: var(--font-body);
		font-size: 17px;
		line-height: 1.65;
		margin: 0;
		color: var(--text);
		max-width: 60ch;
	}
	.t-meta {
		font-family: var(--font-mono);
		font-size: 12px;
		letter-spacing: 0.08em;
		color: var(--muted);
		margin: 0;
	}

	/* Status labels */
	.labels {
		display: flex;
		flex-wrap: wrap;
		gap: 10px;
	}
	.tag {
		font-family: var(--font-mono);
		font-size: 11.5px;
		letter-spacing: 0.04em;
		padding: 4px 10px;
		border-radius: 4px;
		background: var(--surface-2);
		color: var(--text-2);
		border: 1px solid var(--border);
	}
	.tag-accent {
		background: var(--accent);
		color: var(--accent-ink);
		border-color: var(--accent);
	}
	.tag-outline {
		background: transparent;
		color: var(--accent);
		border-color: var(--accent);
	}

	/* Index list */
	.index,
	.shelf {
		list-style: none;
		margin: 0;
		padding: 0;
	}
	.index-item {
		display: flex;
		justify-content: space-between;
		gap: 24px;
		padding: 18px 0;
		border-top: 1px solid var(--border);
	}
	.index-item:last-child {
		border-bottom: 1px solid var(--border);
	}
	.ii-main h3 {
		font-family: var(--font-display);
		font-weight: 500;
		font-size: 20px;
		margin: 0 0 6px;
		color: var(--text);
	}
	.ii-main p {
		margin: 0;
		font-size: 15px;
		line-height: 1.5;
		color: var(--text-2);
		max-width: 48ch;
	}
	.ii-meta {
		font-family: var(--font-mono);
		font-size: 11.5px;
		letter-spacing: 0.03em;
		color: var(--muted);
		white-space: nowrap;
		margin: 4px 0 0;
	}

	/* Bookshelf */
	.book {
		display: flex;
		align-items: flex-start;
		gap: 16px;
		padding: 18px 0;
		border-top: 1px solid var(--border);
	}
	.book:last-child {
		border-bottom: 1px solid var(--border);
	}
	.cover {
		flex: none;
		width: 44px;
		height: 64px;
		border-radius: 3px;
		background: linear-gradient(150deg, var(--surface-2), var(--accent-soft));
		border: 1px solid var(--border);
	}
	.book-main {
		flex: 1;
	}
	.book-main h3 {
		font-family: var(--font-display);
		font-weight: 500;
		font-size: 18px;
		margin: 0 0 2px;
		color: var(--text);
	}
	.book-author {
		margin: 0 0 6px;
		font-size: 14px;
		color: var(--text-2);
	}
	.book-why {
		margin: 0;
		font-size: 14px;
		line-height: 1.45;
		color: var(--muted);
		font-style: italic;
	}

	/* Photo album */
	.album {
		display: flex;
		gap: 18px;
		align-items: stretch;
	}
	.album-img {
		flex: none;
		width: 168px;
		height: 120px;
		border-radius: 6px;
		border: 1px solid var(--border);
		background:
			radial-gradient(120% 90% at 20% 10%, var(--accent-soft), transparent 60%),
			linear-gradient(160deg, var(--surface-2), var(--surface));
	}
	.album-meta h3 {
		font-family: var(--font-display);
		font-weight: 500;
		font-size: 19px;
		margin: 0 0 6px;
		color: var(--text);
	}
	.album-why {
		margin: 0 0 8px;
		font-size: 14.5px;
		line-height: 1.5;
		color: var(--text-2);
		max-width: 42ch;
	}

	/* AI log */
	.log {
		border-left: 2px solid var(--accent);
		padding: 2px 0 2px 18px;
	}
	.log h3 {
		font-family: var(--font-display);
		font-weight: 500;
		font-size: 20px;
		margin: 8px 0 8px;
		color: var(--text);
	}
	.log p {
		margin: 0;
		font-size: 15px;
		line-height: 1.55;
		color: var(--text-2);
		max-width: 54ch;
	}
	.log-lesson {
		margin-top: 12px !important;
		font-size: 14px !important;
		color: var(--text) !important;
	}
	.lesson-key {
		font-family: var(--font-mono);
		font-size: 11px;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--accent);
		margin-right: 8px;
	}

	/* Project */
	.project {
		border: 1px solid var(--border);
		border-radius: 8px;
		background: var(--surface);
		padding: 22px;
	}
	.project-head {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 16px;
		margin-bottom: 6px;
	}
	.project-head h3 {
		font-family: var(--font-display);
		font-weight: 600;
		font-size: 21px;
		margin: 0;
		color: var(--text);
	}
	.project > p {
		margin: 0 0 18px;
		font-size: 15px;
		color: var(--text-2);
	}
	.meta-table {
		margin: 0;
		display: grid;
		gap: 0;
	}
	.meta-table > div {
		display: flex;
		gap: 16px;
		padding: 9px 0;
		border-top: 1px solid var(--border);
	}
	.meta-table dt {
		font-family: var(--font-mono);
		font-size: 11.5px;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		color: var(--muted);
		flex: none;
		width: 132px;
		margin: 0;
	}
	.meta-table dd {
		margin: 0;
		font-size: 14.5px;
		color: var(--text);
	}

	/* Contact */
	.contact {
		display: flex;
		flex-direction: column;
		gap: 16px;
	}
	.contact-line {
		font-family: var(--font-display);
		font-size: 19px;
		line-height: 1.4;
		margin: 0;
		color: var(--text);
		max-width: 40ch;
	}
	.elsewhere {
		display: flex;
		flex-wrap: wrap;
		gap: 18px;
	}
	.elsewhere a {
		font-family: var(--font-mono);
		font-size: 13px;
		color: var(--accent);
		text-decoration: none;
		border-bottom: 1px solid transparent;
		transition: border-color 0.15s;
	}
	.elsewhere a:hover,
	.elsewhere a:focus-visible {
		border-color: var(--accent);
	}

	@media (max-width: 560px) {
		.brand {
			align-items: flex-start;
		}
		.index-item {
			flex-direction: column;
			gap: 6px;
		}
		.album {
			flex-direction: column;
		}
		.album-img {
			width: 100%;
		}
	}
</style>
